<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Open Graph (iMessage, Slack, Discord, etc.) -->
    <meta property="og:title" content="Download {{PROJECT_NAME}}">
    <meta property="og:description" content="{{PLUGIN_DESCRIPTION}}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://{{GITHUB_USER}}.github.io/{{GITHUB_REPO}}/">
    <meta property="og:image" content="https://raw.githubusercontent.com/{{GITHUB_USER}}/{{GITHUB_REPO}}/main/{{PROJECT_NAME}}.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Download {{PROJECT_NAME}}">
    <meta name="twitter:description" content="{{PLUGIN_DESCRIPTION}}">
    <meta name="twitter:image" content="https://raw.githubusercontent.com/{{GITHUB_USER}}/{{GITHUB_REPO}}/main/{{PROJECT_NAME}}.png">

    <title>Download {{PROJECT_NAME}}</title>

    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        text-align: center;
        background: #f5f5f7;
        color: #1d1d1f;
        padding: 3em 2em;
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .container {
        max-width: 600px;
        width: 100%;
        margin: 0 auto;
        background: white;
        padding: 3em;
        border-radius: 18px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      }
      h1 {
        font-size: 2.5em;
        font-weight: 600;
        margin: 0 0 0.5em 0;
        color: #1d1d1f;
      }
      p {
        font-size: 1.2em;
        color: #6e6e73;
        margin: 0 0 2em 0;
      }
      .spinner {
        display: inline-block;
        width: 40px;
        height: 40px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #007aff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 2em 0;
      }
      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
      .status {
        font-size: 0.95em;
        color: #86868b;
        margin-top: 2em;
      }
      a {
        color: #007aff;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .download-links {
        margin-top: 2em;
        padding: 1.5em;
        background: #f5f5f7;
        border-radius: 12px;
      }
      .download-links h3 {
        margin: 0 0 1em 0;
        font-size: 1.1em;
        font-weight: 600;
        color: #1d1d1f;
      }
      .download-links a {
        display: block;
        margin: 0.5em 0;
        padding: 0.75em 1em;
        background: white;
        border-radius: 8px;
        transition: background 0.2s;
      }
      .download-links a:hover {
        background: #e8e8ed;
        text-decoration: none;
      }
    </style>

    <script>
      (async () => {
        const statusEl = document.getElementById("status");
        const linksEl = document.getElementById("manual-links");

        try {
          statusEl.textContent = "Fetching latest release...";

          const res = await fetch("https://api.github.com/repos/{{GITHUB_USER}}/{{GITHUB_REPO}}/releases/latest", {
            headers: { "Accept": "application/vnd.github+json" }
          });

          if (!res.ok) throw new Error("Failed to fetch release");

          const json = await res.json();
          const pkgAsset = (json.assets || []).find(a => a.name && a.name.endsWith(".pkg"));
          const dmgAsset = (json.assets || []).find(a => a.name && a.name.endsWith(".dmg"));
          const zipAsset = (json.assets || []).find(a => a.name && a.name.endsWith(".zip"));

          // Show manual download links
          let linksHTML = '<h3>Download Options:</h3>';
          if (pkgAsset) linksHTML += `<a href="${pkgAsset.browser_download_url}">📦 PKG Installer (${(pkgAsset.size / 1024 / 1024).toFixed(1)} MB)</a>`;
          if (dmgAsset) linksHTML += `<a href="${dmgAsset.browser_download_url}">💿 DMG Disk Image (${(dmgAsset.size / 1024 / 1024).toFixed(1)} MB)</a>`;
          if (zipAsset) linksHTML += `<a href="${zipAsset.browser_download_url}">🗜️ ZIP Archive (${(zipAsset.size / 1024 / 1024).toFixed(1)} MB)</a>`;

          if (pkgAsset || dmgAsset || zipAsset) {
            linksEl.innerHTML = linksHTML;
            linksEl.style.display = 'block';
          }

          if (pkgAsset && pkgAsset.browser_download_url) {
            statusEl.textContent = "Starting download...";

            // Auto-redirect to PKG after a short delay
            setTimeout(() => {
              window.location.replace(pkgAsset.browser_download_url);
              statusEl.innerHTML = `Download started! If not, <a href="${pkgAsset.browser_download_url}">click here</a>.`;
            }, 1500);
          } else {
            throw new Error("No installer found in latest release");
          }
        } catch (e) {
          console.error(e);
          statusEl.innerHTML = `Couldn't find the latest installer. Please visit the <a href="https://github.com/{{GITHUB_USER}}/{{GITHUB_REPO}}/releases/latest">releases page</a>.`;
        }
      })();
    </script>
  </head>

  <body>
    <div class="container">
      <h1>{{PROJECT_NAME}}</h1>
      <p>{{PLUGIN_DESCRIPTION}}</p>
      <div class="spinner"></div>
      <div class="status" id="status">Preparing download...</div>
      <div class="download-links" id="manual-links" style="display: none;"></div>
    </div>
  </body>
</html>
