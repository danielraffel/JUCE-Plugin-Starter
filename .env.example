# JUCE Starter Template Environment Configuration
# Copy this file to .env and customize for your environment

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔄 AUTO-LOADED BY init_plugin_project.sh
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These variables are automatically loaded from your .env when creating new projects
# You'll only see: "For your Y you entered 'X' in your .env - Is this correct? (Y/n)" if they differ from defaults
# This speeds up project creation by reusing your customized developer settings

# Your name/company + creates smart bundle ID defaults
DEVELOPER_NAME="Your Name"

# Directory Path to project folder
PROJECT_PATH=~/Code/JUCE-Plugin-Starter

# Apple Developer settings (for code signing/notarization)
APPLE_ID=your.email@example.com
TEAM_ID=YOURTEAMID
APP_CERT="Developer ID Application: Your Name (TEAMID)"
INSTALLER_CERT="Developer ID Installer: Your Name (TEAMID)"
# Generate at: https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Your GitHub username
GITHUB_USER=yourusername

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ USED BY scripts/build.sh AND OTHER BUILD SCRIPTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These variables configure build behavior, code signing, and distribution
# Created automatically when you run init_plugin_project.sh

# Project identification (auto-generated by init_plugin_project.sh)
PROJECT_NAME=JUCE-Plugin-Starter
PRODUCT_NAME="JUCE Plugin Starter"
BUNDLE_ID=org.danielraffel.JUCE-Plugin-Starter

# Plugin description for GitHub Pages landing page (optional)
PLUGIN_DESCRIPTION="Download the latest version of JUCE Plugin Starter"

# JUCE Plugin Codes (4-letter identifiers auto-generated)
PLUGIN_CODE=XXXX              # Auto-generated from plugin name
PLUGIN_MANUFACTURER_CODE=XXXX # Auto-generated from developer name

# Version Information
BASE_PROJECT_VERSION="1.0."
VERSION_MAJOR=0
VERSION_MINOR=0
VERSION_PATCH=1

# JUCE Starter Template Environment Configuration
JUCE_REPO=https://github.com/juce-framework/JUCE.git
JUCE_TAG=8.0.10  # Can use main for latest (not recommended for production)

# Which platforms to build in CI (comma-separated)
# Options: macos, windows, linux (or "all" to auto-detect)
# If unset, CI auto-detects from project files (build.ps1 = Windows, CMakeLists.txt guards = Linux)
# This also controls which platforms /juce-dev:ci triggers
CI_PLATFORMS="macos"

# Which plugin formats to build (space-separated)
# macOS: AU AUv3 VST3 CLAP Standalone
# Windows: VST3 CLAP Standalone
# Linux: VST3 CLAP Standalone
BUILD_FORMATS="AU AUv3 VST3 CLAP Standalone"

# Default build configuration
DEFAULT_CONFIG=Debug  # Debug, Release, or Prod

# Copy plugins to system folders after build
COPY_AFTER_BUILD=TRUE

# Include accessibility support
INCLUDE_ACCESSKIT=FALSE

# Platform Specific - macOS
OSX_DEPLOYMENT_TARGET=10.15
OSX_ARCHITECTURES="arm64;x86_64"  # Universal binary

# Platform Specific - Windows (only needed when building on Windows)

# ── Windows Code Signing (Option A: Traditional Authenticode) ────────
# Buy a code signing certificate from a CA (Sectigo, DigiCert, GlobalSign, etc.)
# Export as .pfx, then base64-encode: base64 -i cert.pfx | pbcopy (macOS)
#   or: certutil -encode cert.pfx cert_base64.txt (Windows)
# WINDOWS_CERT_PFX_BASE64=
# WINDOWS_CERT_PASSWORD=

# ── Windows Code Signing (Option B: Azure Trusted Signing) ──────────
# Cloud-based signing (~$10/month). Instant SmartScreen reputation.
# See: https://learn.microsoft.com/en-us/azure/trusted-signing/
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_SIGNING_ACCOUNT=your-account
# AZURE_SIGNING_PROFILE=your-profile
# AZURE_SIGNING_ENDPOINT=https://eus.codesigning.azure.net

# ── Website Configuration ────────────────────────────────────────────
# For private repos: set this to publish website/releases to a separate public repo
# WEBSITE_REPO=

# GitHub Release Settings
# Project-specific repository and tokens
GITHUB_REPO=JUCE-Plugin-Starter
#GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Auto-Update Configuration ──────────────────────
# Enable auto-update support (Sparkle on macOS, WinSparkle on Windows)
ENABLE_AUTO_UPDATE=false

# Distribution mode: "public" (default) or "private" (advanced, Phase B)
AUTO_UPDATE_MODE=public

# EdDSA signing key (base64, generated by Sparkle generate_keys or WinSparkle winsparkle-tool)
AUTO_UPDATE_EDDSA_PUBLIC_KEY=

# Per-platform appcast feed URLs (set automatically during setup)
AUTO_UPDATE_FEED_URL_MACOS=
AUTO_UPDATE_FEED_URL_WINDOWS=
AUTO_UPDATE_FEED_URL_LINUX=

# Private distribution (Phase B — commercial plugins with private release repos)
# Set to "true" to embed a GitHub PAT in the binary for authenticated downloads
# The PAT itself goes in AUTO_UPDATE_DOWNLOAD_PAT (keep this in .env, never commit)
# SPARKLE_EMBED_UPDATE_PAT=false
# AUTO_UPDATE_DOWNLOAD_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Split-repo pattern (advanced — for private source code with public downloads)
# Leave empty to publish releases and appcast to this repo (default)
# RELEASE_REPO=owner/my-plugin-releases    # GitHub repo for releases + latest.json
# APPCAST_REPO=owner/my-plugin-appcast     # GitHub repo for appcast XML feeds
# RELEASE_REPO_PAT is stored as a GitHub Secret, not here

# Development Settings
# Use sanitizers in debug builds
USE_SANITIZER=FALSE

# Verbose build output
CMAKE_VERBOSE=FALSE

# Number of parallel build jobs (0 = auto-detect)
BUILD_JOBS=0

# Audio/MIDI Settings Defaults
# Default sample rate for standalone
DEFAULT_SAMPLE_RATE=48000

# Default buffer size for standalone
DEFAULT_BUFFER_SIZE=256

# Enable MIDI input by default
ENABLE_MIDI_INPUT=TRUE

# Enable MIDI output by default
ENABLE_MIDI_OUTPUT=FALSE

# Demo Application Settings
# Show demo tabs in release builds
SHOW_DEMO_TABS=TRUE

# Enable GPU profiling overlay
ENABLE_GPU_PROFILER=FALSE

# Enable audio performance metrics
ENABLE_AUDIO_METRICS=TRUE

# Testing Configuration
# Run tests after build
RUN_TESTS_AFTER_BUILD=FALSE

# Plugin validation strictness (1-10)
PLUGINVAL_STRICTNESS=5

# Documentation
# Generate documentation during build
GENERATE_DOCS=FALSE

# Documentation output directory
DOCS_OUTPUT_DIR=docs/generated

# Build number (auto-incremented)
VERSION_BUILD=0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 📝 RELEASE NOTES GENERATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Configure how release notes are generated when you run: ./scripts/build.sh publish

# Choose your release notes generation method:
# - "claude"     = Use Claude Code interactively (best quality, requires Claude Code running)
# - "openrouter" = Use OpenRouter API automatically (good quality, requires API key)
# - "openai"     = Use OpenAI API automatically (good quality, requires API key)
# - "auto"       = Try AI APIs if keys available, otherwise use Python categorization
# - "none"       = Use Python script categorization only (no AI, always works)
RELEASE_NOTES_METHOD=claude

# AI API Keys (only needed if using openrouter/openai/auto methods)
# Get OpenRouter key at: https://openrouter.ai/keys
OPENROUTER_KEY_PRIVATE=or-v1-xxxxxxxxxxxx

# OpenAI API key as alternative
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# AI model to use for release notes generation (only used with openrouter/auto methods)
# OpenRouter models: openai/gpt-4o-mini, anthropic/claude-3-opus, google/gemini-pro-1.5
# OpenAI models: gpt-4o-mini, gpt-4o
RELEASE_NOTES_MODEL=openai/gpt-4o-mini

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# How each method works:
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# "claude"     → Shows commits to Claude Code → Claude generates notes → Auto-publishes
# "openrouter" → Automatically uses OpenRouter API → Auto-publishes (requires key)
# "openai"     → Automatically uses OpenAI API → Auto-publishes (requires key)
# "auto"       → Tries OpenRouter/OpenAI if keys exist, falls back to Python
# "none"       → Uses Python categorization only (Features/Fixes/Improvements)
